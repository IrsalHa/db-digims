OPTIONS (SKIP=1, DIRECT=TRUE, ERRORS=10, COLUMNARRAYROWS=10000, READSIZE=8388608)
LOAD DATA
INFILE '/opt/oracle/MPRODUCTGROUP_DATA.csv'
INTO TABLE MPRODUCTGROUP
APPEND
FIELDS TERMINATED BY '~'

(
    MPRODUCTGROUPPK  INTEGER EXTERNAL NULLIF MPRODUCTGROUPPK = 'NULL',
    PRODUCTGROUPCODE CHAR(2) NULLIF PRODUCTGROUPCODE = 'NULL',
    PRODUCTGROUP     CHAR(40) NULLIF PRODUCTGROUP = 'NULL',
    ISCOA            CHAR(1) NULLIF ISCOA = 'NULL'
)
