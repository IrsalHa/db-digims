OPTIONS (SKIP=1, DIRECT=TRUE, ERRORS=10, BINDSIZE=8000000, COLUMNARRAYROWS=10000, READSIZE=8388608)
LOAD DATA
INFILE '/opt/oracle/tp_dpensiuncln_data4.csv'
INTO TABLE TP_DPENSIUNCLN
APPEND
FIELDS TERMINATED BY '#' OPTIONALLY ENCLOSED BY '"'

