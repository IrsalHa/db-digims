    SYS_STATUS          CHAR NULLIF SYS_STATUS = 'NULL',
    TGL_MENINGGAL       TIMESTAMP "YYYY-MM-DD HH24:MI:SS.FF" NULLIF TGL_MENINGGAL = 'NULL',
    SK_FLAG             INTEGER EXTERNAL NULLIF SK_FLAG = 'NULL',
    KD_STATUS_TEMP      CHAR NULLIF KD_STATUS_TEMP = 'NULL',
    DOK_NAME            CHAR NULLIF DOK_NAME = 'NULL',
    KD_SETOR            CHAR NULLIF KD_SETOR = 'NULL',
    TGL_SETOR           TIMESTAMP "YYYY-MM-DD HH24:MI:SS.FF" NULLIF TGL_SETOR = 'NULL',
    KD_SETOR_TEMP       CHAR NULLIF KD_SETOR_TEMP = 'NULL',
    ERRCODE             CHAR NULLIF ERRCODE = 'NULL',
    APPROVED_BY         CHAR NULLIF APPROVED_BY = 'NULL',
    BRANCH_USERID       CHAR NULLIF BRANCH_USERID = 'NULL',
    BRANCH_SPV          CHAR NULLIF BRANCH_SPV = 'NULL',
    HOLD_NUM            CHAR NULLIF HOLD_NUM = 'NULL',
    BATCH_ID            CHAR NULLIF BATCH_ID = 'NULL',
    VERIFIED_BY         CHAR NULLIF VERIFIED_BY = 'NULL',
    APP_VERIFIED_BY     CHAR NULLIF APP_VERIFIED_BY = 'NULL',
    REASON_REJECT       CHAR NULLIF REASON_REJECT = 'NULL',
    FPOSTING            INTEGER EXTERNAL NULLIF FPOSTING = 'NULL',
    REK_SUMBER          CHAR NULLIF REK_SUMBER = 'NULL',
    REK_TUJUAN          CHAR NULLIF REK_TUJUAN = 'NULL',
    REK_PRT_RETUR       CHAR NULLIF REK_PRT_RETUR = 'NULL',
    BRANCH_KCK_STR      CHAR NULLIF BRANCH_KCK_STR = 'NULL',
    BATCH_NO            CHAR NULLIF BATCH_NO = 'NULL',
    REKORG              CHAR NULLIF REKORG = 'NULL',
    FLPROC              INTEGER EXTERNAL NULLIF FLPROC = 'NULL',
    REFNUM              CHAR NULLIF REFNUM = 'NULL',
    TGL_TEMP_KD_STATUS  TIMESTAMP "YYYY-MM-DD HH24:MI:SS.FF" NULLIF TGL_TEMP_KD_STATUS = 'NULL',
    KD_STATUS_OLD       CHAR NULLIF KD_STATUS_OLD = 'NULL',
